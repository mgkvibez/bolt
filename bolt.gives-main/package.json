{
  "name": "bolt.gives",
  "productName": "bolt.gives",
  "description": "bolt.gives collaborative AI agent",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "version": "3.0.9.3",
  "author": {
    "name": "bolt.gives team",
    "email": "maintainers@bolt.gives"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "deploy": "npm run build && wrangler pages deploy",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=18432 remix vite:build && node scripts/postbuild-fixes.mjs",
    "build:highmem": "cross-env NODE_OPTIONS=--max-old-space-size=18432 remix vite:build && node scripts/postbuild-fixes.mjs",
    "dev": "cross-env-shell NODE_OPTIONS=--max-old-space-size=18432 \"node pre-start.cjs && concurrently \\\"pnpm run collab:server\\\" \\\"pnpm run webbrowse:server\\\" \\\"remix vite:dev\\\" --names collab,webbrowse,app --kill-others-on-fail\"",
    "collab:server": "node scripts/collaboration-server.mjs",
    "webbrowse:server": "node scripts/web-browse-server.mjs",
    "setup": "node scripts/setup.mjs",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=18432 vitest --run",
    "test:watch": "cross-env NODE_OPTIONS=--max-old-space-size=18432 vitest",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint app",
    "lint:fix": "npm run lint -- --fix && prettier app --write",
    "start:windows": "node scripts/start-pages-dev.mjs",
    "prepare:devvars": "node scripts/prepare-dev-vars.mjs",
    "start:unix": "node scripts/start-pages-dev.mjs",
    "start": "node scripts/start-pages-dev.mjs",
    "dockerstart": "node scripts/start-pages-dev.mjs --ip 0.0.0.0 --port 5173 --no-show-interactive-dev-session",
    "dockerrun": "docker run -it -d --name bolt-ai-live -p 5173:5173 --env-file .env.local bolt-ai",
    "dockerbuild:prod": "docker build -t bolt-ai:production -t bolt-ai:latest --target bolt-ai-production .",
    "dockerbuild": "docker build -t bolt-ai:development -t bolt-ai:latest --target development .",
    "commentary:generate": "node scripts/generate-commentary-pool.mjs",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=18432 tsc --pretty false --incremental",
    "gate:release": "node scripts/release-gate.mjs",
    "gate:release:live": "RELEASE_GATE_DOMAINS=https://alpha1.bolt.gives,https://ahmad.bolt.gives node scripts/release-gate.mjs",
    "e2e:preview-recovery": "node scripts/e2e-preview-auto-recovery.mjs",
    "e2e:free-startup": "node scripts/e2e-free-startup-label.mjs",
    "smoke:live": "node scripts/live-release-smoke.mjs",
    "health:postdeploy": "node scripts/post-deploy-health-check.mjs",
    "smoke:self-host-installer": "node scripts/self-host-installer-smoke.mjs",
    "budget:client": "node scripts/client-bundle-budget.mjs",
    "typegen": "wrangler types",
    "preview": "pnpm run build && pnpm run start",
    "postinstall": "node scripts/install-playwright.mjs",
    "prepare": "husky",
    "clean": "node scripts/clean.js",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:dev:inspect": "NODE_ENV=development electron --inspect=9229 build/electron/main/index.mjs",
    "electron:build:deps": "concurrently \"pnpm electron:build:main\" \"pnpm electron:build:preload\" --kill-others-on-fail",
    "electron:build:main": "vite build --config ./electron/main/vite.config.ts",
    "electron:build:preload": "vite build --config ./electron/preload/vite.config.ts",
    "electron:build:renderer": "remix vite:build --config vite-electron.config.js",
    "electron:build:unpack": "rm -rf dist && pnpm electron:build:renderer && pnpm electron:build:deps && electron-builder --dir",
    "electron:build:mac": "rm -rf dist && pnpm electron:build:renderer && pnpm electron:build:deps && electron-builder --mac",
    "electron:build:win": "rm -rf dist && pnpm electron:build:renderer && pnpm electron:build:deps && electron-builder --win",
    "electron:build:linux": "rm -rf dist && pnpm electron:build:renderer && pnpm electron:build:deps && electron-builder --linux",
    "electron:build:dist": "rm -rf dist && pnpm electron:build:renderer && pnpm electron:build:deps && electron-builder --mwl",
    "tauri:dev": "tauri dev",
    "tauri:build": "pnpm build && tauri build",
    "mobile:ios": "cd apps/mobile && pnpm expo start --ios",
    "mobile:android": "cd apps/mobile && pnpm expo start --android",
    "mobile:web": "cd apps/mobile && pnpm expo start --web",
    "dev:monorepo": "concurrently \"pnpm run dev\" \"pnpm run mobile:web\""
  },
  "engines": {
    "node": ">=18.18.0"
  },
